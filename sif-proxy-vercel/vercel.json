{
  "rewrites": [
    { "source": "/api/mcp", "destination": "/api/mcp" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, secret-key, Accept" }
      ]
    }
  ]
}
